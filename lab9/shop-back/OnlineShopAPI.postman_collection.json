{
    "info": {
      "name": "Online Shop API",
      "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
      {
        "name": "Categories",
        "item": [
          {"name": "Get All Categories", "request": {"method": "GET", "url": "http://localhost:8000/api/categories/"}},
          {"name": "Get Category by ID", "request": {"method": "GET", "url": "http://localhost:8000/api/categories/1/"}},
          {"name": "Get Products by Category", "request": {"method": "GET", "url": "http://localhost:8000/api/categories/1/products/"}},
          {"name": "Create Category", "request": {"method": "POST", "url": "http://localhost:8000/api/categories/", "body": {"mode": "raw", "raw": "{\"name\": \"Electronics\", \"description\": \"Electronic devices\"}", "options": {"raw": {"language": "json"}}}}},
          {"name": "Update Category", "request": {"method": "PUT", "url": "http://localhost:8000/api/categories/1/", "body": {"mode": "raw", "raw": "{\"name\": \"Updated Category\", \"description\": \"Updated\"}", "options": {"raw": {"language": "json"}}}}},
          {"name": "Delete Category", "request": {"method": "DELETE", "url": "http://localhost:8000/api/categories/1/"}}
        ]
      },
      {
        "name": "Products",
        "item": [
          {"name": "Get All Products", "request": {"method": "GET", "url": "http://localhost:8000/api/products/"}},
          {"name": "Get Product by ID", "request": {"method": "GET", "url": "http://localhost:8000/api/products/1/"}},
          {"name": "Create Product", "request": {"method": "POST", "url": "http://localhost:8000/api/products/", "body": {"mode": "raw", "raw": "{\"name\": \"Laptop\", \"description\": \"Gaming laptop\", \"price\": \"999.99\", \"category\": 1, \"stock\": 10}", "options": {"raw": {"language": "json"}}}}},
          {"name": "Update Product", "request": {"method": "PUT", "url": "http://localhost:8000/api/products/1/", "body": {"mode": "raw", "raw": "{\"name\": \"Updated Laptop\", \"description\": \"Updated\", \"price\": \"899.99\", \"category\": 1, \"stock\": 5}", "options": {"raw": {"language": "json"}}}}},
          {"name": "Delete Product", "request": {"method": "DELETE", "url": "http://localhost:8000/api/products/1/"}}
        ]
      }
    ]
